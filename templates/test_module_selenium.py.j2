# ---------------------------------------------------------------------------
# Helper
# ---------------------------------------------------------------------------

def _el(driver, by, selector, timeout=IMPLICIT_WAIT):
    """Fetch a single element with an explicit wait."""
    return WebDriverWait(driver, timeout).until(
        EC.presence_of_element_located((by, selector))
    )


def _text(driver, by, selector, timeout=IMPLICIT_WAIT):
    """Return .text of a located element (stripped)."""
    return _el(driver, by, selector, timeout).text.strip()


def _val(driver, by, selector, timeout=IMPLICIT_WAIT):
    """Return the value attribute of a located element (input/select)."""
    return _el(driver, by, selector, timeout).get_attribute("value") or ""


